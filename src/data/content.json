  "testimonials": [
    {
      "text": "Sūnus praleido nuostabią savaitę Bricks4Kidz stovykloje – kiekvieną dieną grįždavo su naujais LEGO robotais ir idėjomis. Tobulai suderintas žaidimas ir mokymasis. Kitą vasarą tikrai grįšim!",
      "author": "Ingrida P., Vilnius · Google atsiliepimas"
    },
    {
      "text": "Little Medical School stovykla – tai ne tik smagu, bet ir labai prasminga. Dukra susipažino su medicinos pagrindais ir grįžo pilna įkvėpimo studijuoti toliau. Ačiū už profesionalumą!",
      "author": "Aurimas K., Kaunas · Google atsiliepimas"
    },
    {
      "text": "Business Kids stovykloje vaikas sukūrė savo verslo idėją ir drąsiai pristatė ją prieš auditoriją. Po stovyklos atsirado pasitikėjimas savimi – neįkainojama patirtis!",
      "author": "Rasa V., Klaipėda · Google atsiliepimas"
    },
    {
      "text": "Puikiai organizuota stovykla – maitinimas skanus, auklėtojai dėmesingi, programa įdomi. Dukra kiekvieną rytą laukė stovyklos dienos. Rekomenduoju visiems tėvams!",
      "author": "Tomas A., Šiauliai · Google atsiliepimas"
    },
    {
      "text": "Po stovyklos sūnus pats pradėjo domėtis programavimu ir robotika. Tai būtent tokia patirtis, kuri pakeičia vaiko požiūrį į mokymąsi. Ačiū visai Bricks4Kidz komandai!",
      "author": "Jūratė M., Vilnius · Google atsiliepimas"
    },
    {
      "text": "Laikas be ekranų, aktyvios veiklos lauke, nauji draugai – tiksliai tai, ko reikėjo šią vasarą. Vaikas grįžo laimingas ir pilnas istorijų. Tikrai renkamės ir kitais metais.",
      "author": "Dovilė Š., Panevėžys · Google atsiliepimas"
    },
    {
      "text": "Veterinarijos modulis Little Medical School stovykloje buvo tiesiog stebuklingas – dukra po jo dar labiau įsimylėjo gyvūnus ir svajoja tapti veterinare. Dėkojame!",
      "author": "Gintarė B., Alytus · Google atsiliepimas"
    },
    {
      "text": "Tarptautinio lygio STEAM programos, puikios patalpos ir pedagogai. Sūnui tai buvo įsimintiniausia vasaros savaitė. Tikrai rekomenduojame kiekvienai šeimai!",
      "author": "Mantas L., Kaunas · Google atsiliepimas"
    }
  ],
